{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
//#if (Postgres)
    "DefaultConnection": "Host=localhost;Database=appdb;Username=postgres;Password=postgres"
//#else
    "DefaultConnection": "Data Source=app.db"
//#endif
  }
}
