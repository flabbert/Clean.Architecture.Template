{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "build",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [ "build", "--no-restore", "--configuration", "Release" ]
      },
      {
         "name": "test",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [ "test", "--no-build", "--configuration", "Release", "--verbosity", "minimal" ]
      }
   ]
}
